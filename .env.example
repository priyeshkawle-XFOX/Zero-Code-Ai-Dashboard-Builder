# ============================================
# AI Dashboard Builder - Environment Variables
# ============================================
# Copy this file to `.env` and fill in your values
# cp .env.example .env

# ============================================
# 🖥️ Backend Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ============================================
# 🌐 CORS Configuration
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# 🤖 AI / Ollama Configuration
# ============================================
# Ollama API endpoint
OLLAMA_URL=http://localhost:11434

# Model to use (phi3, llama2, mistral, codellama, etc.)
OLLAMA_MODEL=phi3

# Maximum tokens to generate
OLLAMA_MAX_TOKENS=100

# Request timeout (seconds)
OLLAMA_TIMEOUT=30

# ============================================
# 📊 ML Model Configuration
# ============================================
# Forecast horizon (number of future periods)
FORECAST_HORIZON=30

# Train/test split ratio (0.0 to 1.0)
TRAIN_TEST_SPLIT=0.6

# ============================================
# 📁 File Upload Configuration
# ============================================
# Maximum file size in bytes (10MB default)
MAX_UPLOAD_SIZE=10485760

# Allowed file extensions
ALLOWED_EXTENSIONS=csv

# ============================================
# 🔐 Security (Future)
# ============================================
# JWT secret key (generate a random string)
# JWT_SECRET_KEY=your-secret-key-here
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=1440

# ============================================
# 🗄️ Database (Future)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/dashboard
# REDIS_URL=redis://localhost:6379/0

# ============================================
# 📧 Email (Future)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-password
